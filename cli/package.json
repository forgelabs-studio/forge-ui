    "picocolors": "^1.0.0",
    "fs-extra": "^11.2.0",
    "detect-package-manager": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.0.0"
  }
}
